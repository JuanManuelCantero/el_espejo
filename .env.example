# ============================================================
# ARCHIVO DE CONFIGURACIÓN DE VARIABLES DE ENTORNO
# ============================================================
# IMPORTANTE: Este archivo es un EJEMPLO
# Crea un archivo .env REAL en la raíz del proyecto con TUS valores
# NUNCA subas el archivo .env a repositorios públicos
# ============================================================

# === CREDENCIALES DE TWITTER ===
# Reemplaza estos valores con tus credenciales reales de Twitter Developer
# Obtén las credenciales en: https://developer.twitter.com/
TWITTER_CONSUMER_KEY=YOUR_CONSUMER_KEY_HERE
TWITTER_CONSUMER_SECRET=YOUR_CONSUMER_SECRET_HERE
TWITTER_ACCESS_TOKEN=YOUR_ACCESS_TOKEN_HERE
TWITTER_TOKEN_SECRET=YOUR_TOKEN_SECRET_HERE

# === CONFIGURACIÓN DE BASE DE DATOS (Futuro) ===
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=el_espejo_db

# === CONFIGURACIÓN DE MAIL ===
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your_email@gmail.com
# MAIL_PASSWORD=your_app_password
# MAIL_FROM_ADDRESS=info@centroelespejo.com.ar

# === SEGURIDAD ===
# APP_ENV=production
# APP_DEBUG=false
# SESSION_PATH=/path/to/sessions
